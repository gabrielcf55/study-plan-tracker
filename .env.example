# Variáveis de ambiente — configure-as na Vercel (Settings → Environment Variables).
# Este arquivo é só um exemplo; não coloque segredos reais aqui (e não comite .env).

# --- Login opcional por senha (Edge Middleware / Basic Auth) ---
# Sem BASIC_AUTH_ENABLED=true, o app fica público (padrão).
BASIC_AUTH_ENABLED=false
BASIC_AUTH_USER=seu_usuario
BASIC_AUTH_PASSWORD=sua_senha

# --- Sincronização entre dispositivos (Upstash Redis) ---
# Normalmente injetadas automaticamente ao conectar o Upstash pelo Marketplace da Vercel.
# O código aceita os dois conjuntos de nomes.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
